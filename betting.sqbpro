CREATE TABLE historical_matches (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    date TEXT,
    league TEXT,
    homeTeam TEXT,
    awayTeam TEXT,

    fthg INTEGER,
    ftag INTEGER,

    homeShots INTEGER,
    awayShots INTEGER,

    homeShotsTarget INTEGER,
    awayShotsTarget INTEGER,

    homeOdds REAL,
    drawOdds REAL,
    awayOdds REAL,

    UNIQUE(date, homeTeam, awayTeam, league)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
